#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import tkinter as tk
from tkinter import ttk, scrolledtext, messagebox
from evasion_techniques import EvasionTechniques

class EvasionDashboard:
    def __init__(self, parent):
        self.parent = parent
        self.evasion = EvasionTechniques()
        self.window = None
        
    def open_dashboard(self):
        if self.window and self.window.winfo_exists():
            self.window.lift()
            return
        
        self.window = tk.Toplevel(self.parent)
        self.window.title("🛡 EVASION TECHNIQUES - Stealth Control Center")
        self.window.geometry("1000x700")
        self.window.configure(bg='#0a0a0a')
        
        # Header
        header = tk.Label(self.window, text="🛡 ADVANCED EVASION TECHNIQUES", 
                         bg='#0a0a0a', fg='#00ff41', font=('Courier', 14, 'bold'))
        header.pack(pady=10)
        
        # Notebook
        notebook = ttk.Notebook(self.window)
        notebook.pack(fill=tk.BOTH, expand=True, padx=10, pady=10)
        
        # Tab 1: Proxy Chains
        self.create_proxy_tab(notebook)
        
        # Tab 2: VPN Rotation
        self.create_vpn_tab(notebook)
        
        # Tab 3: MAC Randomization
        self.create_mac_tab(notebook)
        
        # Tab 4: Traffic Shaping
        self.create_traffic_tab(notebook)
        
        # Tab 5: IDS/IPS Fingerprinting
        self.create_ids_tab(notebook)
        
        # Output area
        output_frame = tk.LabelFrame(self.window, text="📊 OUTPUT", 
                                     bg='#1a1a1a', fg='#00ff41', font=('Courier', 10, 'bold'))
        output_frame.pack(fill=tk.BOTH, expand=True, padx=10, pady=10)
        
        self.output_text = scrolledtext.ScrolledText(output_frame, height=10,
                                                      bg='#0a0a0a', fg='#00ff41',
                                                      font=('Courier', 9))
        self.output_text.pack(fill=tk.BOTH, expand=True, padx=5, pady=5)
        
        self.output_text.tag_config('info', foreground='#00ccff')
        self.output_text.tag_config('success', foreground='#00ff41')
        self.output_text.tag_config('error', foreground='#ff3333')
        self.output_text.tag_config('warning', foreground='#ffcc00')
        
        self.log_output("🛡 EVASION TECHNIQUES READY", 'success')
        self.log_output("📌 Select a technique from the tabs above", 'info')
    
    def log_output(self, text, tag='info'):
        self.output_text.insert(tk.END, text + "\n", tag)
        self.output_text.see(tk.END)
    
