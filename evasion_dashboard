    # ========== PROXY FUNCTIONS ==========
    
    def enable_tor(self):
        success, msg = self.evasion.setup_tor_proxy()
        self.log_output(f"\n🔌 Tor Proxy: {msg}", 'success' if success else 'error')
    
    def enable_socks(self):
        host = self.socks_host.get()
        port = int(self.socks_port.get())
        success, msg = self.evasion.setup_socks_proxy(host, port)
        self.log_output(f"\n🔌 SOCKS5 Proxy: {msg}", 'success' if success else 'error')
    
    def enable_http(self):
        host = self.http_host.get()
        port = int(self.http_port.get()) if self.http_port.get() else 8080
        success, msg = self.evasion.setup_http_proxy(host, port)
        self.log_output(f"\n🔌 HTTP Proxy: {msg}", 'success' if success else 'error')
    
    def test_proxy(self):
        success, msg = self.evasion.test_proxy()
        self.log_output(f"\n🧪 Proxy Test: {msg}", 'success' if success else 'error')
    
    # ========== VPN FUNCTIONS ==========
    
    def check_vpn(self):
        success, msg = self.evasion.check_vpn_status()
        self.vpn_status_label.config(text=f"VPN: {msg}")
        self.log_output(f"\n🔒 VPN Status: {msg}", 'success' if success else 'info')
    
    def rotate_vpn(self):
        config = self.vpn_config.get()
        success, msg = self.evasion.rotate_vpn(config)
        self.log_output(f"\n🔄 VPN Rotation: {msg}", 'success' if success else 'error')
    
    def get_ip(self):
        ip = self.evasion.get_public_ip()
        self.ip_label.config(text=f"Public IP: {ip}")
        self.log_output(f"\n🌐 Public IP: {ip}", 'info')
    
    # ========== MAC FUNCTIONS ==========
    
    def get_current_mac(self):
        interface = self.mac_interface.get()
        mac = self.evasion.get_current_mac(interface)
        if mac:
            self.current_mac_label.config(text=f"Current MAC: {mac}")
            self.log_output(f"\n🔧 Current MAC for {interface}: {mac}", 'info')
        else:
            self.log_output(f"\n🔧 Could not get MAC for {interface}", 'error')
    
    def randomize_mac(self):
        interface = self.mac_interface.get()
        success, msg = self.evasion.change_mac_address(interface)
        self.log_output(f"\n🎲 MAC Randomization: {msg}", 'success' if success else 'error')
        self.get_current_mac()
    
    def restore_mac(self):
        interface = self.mac_interface.get()
        success, msg = self.evasion.restore_mac_address(interface)
        self.log_output(f"\n🔄 MAC Restore: {msg}", 'success' if success else 'error')
        self.get_current_mac()
    
    # ========== TRAFFIC FUNCTIONS ==========
    
    def enable_traffic_shaping(self):
        rate = self.rate_limit.get()
        burst = self.burst_limit.get()
        success, msg = self.evasion.setup_traffic_shaping(rate, burst)
        self.log_output(f"\n📊 Traffic Shaping: {msg}", 'success' if success else 'error')
    
    def generate_delay_command(self):
        delay = self.delay_ms.get()
        cmd = self.evasion.set_scan_delay(int(delay))
        self.delay_command_label.config(text=f"Command: {cmd}")
        self.log_output(f"\n⚡ Generated: {cmd}", 'info')
    
    def remove_traffic_shaping(self):
        success, msg = self.evasion.remove_traffic_shaping()
        self.log_output(f"\n⛔ Traffic Shaping: {msg}", 'success' if success else 'error')
    
    # ========== IDS/IPS FUNCTIONS ==========
    
    def detect_firewall(self):
        target = self.ids_target.get()
        results = self.evasion.detect_firewall(target)
        output = self.evasion.format_output("IDS/IPS DETECTION", results)
        self.log_output(output, 'info')
    
    def test_os_fingerprinting(self):
        target = self.ids_target.get()
        success, msg = self.evasion.detect_os_fingerprinting_block(target)
        self.log_output(f"\n🎯 OS Fingerprinting: {msg}", 'success' if success else 'warning')
    
    def generate_evasion_commands(self):
        commands = self.evasion.get_evasion_commands()
        self.cmd_text.delete(1.0, tk.END)
        self.cmd_text.insert(1.0, "\n".join(commands))
        self.log_output(f"\n📋 Generated {len(commands)} evasion commands", 'success')
